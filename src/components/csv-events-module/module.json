{
  "name": "dcsve/csv-events",
  "d4Shortcode": "",
  "title": "CSV Events",
  "titles": "CSV Events",
  "moduleIcon": "dcsve/csv-events",
  "moduleClassName": "dcsve_csv_events",
  "moduleOrderClassName": "dcsve_csv_events",
  "category": "module",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "advanced": {
          "text": {
            "text": {
              "desktop": {
                "value": {
                  "color": "light"
                }
              }
            }
          }
        }
      },
      "styleProps": {
        "border": {
          "important": true
        }
      },
      "settings": {
        "meta": {
          "adminLabel": {}
        },
        "advanced": {
          "link": {},
          "text": {},
          "htmlAttributes": {}
        },
        "decoration": {
          "background": {},
          "sizing": {},
          "spacing": {},
          "border": {},
          "boxShadow": {},
          "filters": {},
          "transform": {},
          "animation": {},
          "overflow": {},
          "disabledOn": {},
          "transition": {},
          "position": {},
          "zIndex": {},
          "scroll": {},
          "sticky": {}
        }
      }
    },
    "csvSourceMode": {
      "type": "object",
      "default": {
        "innerContent": { "desktop": { "value": { "mode": "file" } } }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentCsvSource",
            "priority": 5,
            "render": true,
            "subName": "mode",
            "label": "CSV Source",
            "description": "Choose how to provide event data.",
            "features": {
              "sticky": false,
              "dynamicContent": false,
              "responsive": false,
              "hover": false
            },
            "component": {
              "name": "divi/select",
              "type": "field",
              "props": {
                "options": {
                  "file":  { "label": "CSV File" },
                  "paste": { "label": "Paste CSV Data" }
                }
              }
            }
          }
        }
      }
    },
    "csvSource": {
      "type": "object",
      "settings": {
        "innerContent": {
          "groupType": "group-items",
          "items": {
            "src": {
              "groupSlug": "contentCsvSource",
              "priority": 10,
              "render": true,
              "subName": "src",
              "label": "CSV File",
              "description": "Upload or select a CSV file. Format: Date;Time;Title;Location;Description",
              "features": {
                "sticky": false,
                "dynamicContent": false,
                "responsive": false,
                "hover": false
              },
              "component": {
                "name": "divi/upload",
                "type": "field",
                "props": {
                  "dataType": "text/csv",
                  "chooseText": "Select CSV File",
                  "uploadButtonText": "Upload CSV",
                  "hideMetadata": true
                }
              }
            }
          }
        }
      }
    },
    "csvContent": {
      "type": "object",
      "default": {
        "innerContent": { "desktop": { "value": { "content": "" } } }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-items",
          "items": {
            "content": {
              "groupSlug": "contentCsvSource",
              "priority": 15,
              "render": true,
              "subName": "content",
              "label": "CSV Data",
              "description": "Paste CSV data directly. Format: Date;Time;Title;Location;Description (max 100 KB)",
              "features": {
                "sticky": false,
                "dynamicContent": false,
                "responsive": false,
                "hover": false
              },
              "component": {
                "name": "divi/textarea",
                "type": "field",
                "props": {
                  "showPlaceholderOnEmpty": true
                }
              }
            }
          }
        }
      }
    },
    "heading": {
      "type": "object",
      "selector": "{{selector}} .dcsve_csv_events__heading",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupName": "mainContent",
            "priority": 10,
            "render": true,
            "attrName": "heading.innerContent",
            "label": "Heading",
            "description": "Optional heading displayed above the events list.",
            "features": {
              "sticky": false,
              "dynamicContent": false
            },
            "component": {
              "name": "divi/text",
              "type": "field"
            }
          }
        },
        "decoration": {
          "font": {
            "priority": 10,
            "component": {
              "props": {
                "groupLabel": "Heading Text",
                "fieldLabel": "Heading",
                "fields": {
                  "headingLevel": {
                    "render": true
                  }
                }
              }
            }
          }
        }
      },
      "tagName": "h3",
      "attributes": {
        "class": "dcsve_csv_events__heading"
      },
      "inlineEditor": "plainText",
      "elementType": "heading",
      "childrenSanitizer": "et_core_esc_previously"
    },
    "dateText": {
      "type": "object",
      "selector": "{{selector}} .dcsve_csv_events__el-date",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "priority": 20,
            "component": {
              "props": {
                "groupLabel": "Date Text",
                "fieldLabel": "Date",
                "fields": {
                  "headingLevel": {
                    "render": false
                  }
                }
              }
            }
          }
        }
      }
    },
    "titleText": {
      "type": "object",
      "selector": "{{selector}} .dcsve_csv_events__el-title",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "priority": 30,
            "component": {
              "props": {
                "groupLabel": "Title Text",
                "fieldLabel": "Title",
                "fields": {
                  "headingLevel": {
                    "render": false
                  }
                }
              }
            }
          }
        }
      }
    },
    "metaText": {
      "type": "object",
      "selector": "{{selector}} .dcsve_csv_events__el-meta",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "priority": 40,
            "component": {
              "props": {
                "groupLabel": "Meta Text",
                "fieldLabel": "Meta",
                "fields": {
                  "headingLevel": {
                    "render": false
                  }
                }
              }
            }
          }
        }
      }
    },
    "descText": {
      "type": "object",
      "selector": "{{selector}} .dcsve_csv_events__el-desc",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "priority": 50,
            "component": {
              "props": {
                "groupLabel": "Description Text",
                "fieldLabel": "Description",
                "fields": {
                  "headingLevel": {
                    "render": false
                  }
                }
              }
            }
          }
        }
      }
    },
    "filterBtn": {
      "type": "object",
      "selector": "{{selector}} .dcsve_csv_events__btn",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "priority": 60,
            "component": {
              "props": {
                "groupLabel": "Filter Buttons",
                "fieldLabel": "Filter",
                "fields": {
                  "headingLevel": {
                    "render": false
                  }
                }
              }
            }
          }
        }
      }
    },
    "eventSettings": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": {
              "period": "year",
              "periodCount": "1",
              "count": "0",
              "showPast": "off",
              "view": "list",
              "showFilter": "on",
              "showViewSwitcher": "on",
              "accentColor": "#2e7d32",
              "organizerName": "",
              "organizerUrl": "",
              "schemaEnabled": "on"
            }
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-items",
          "items": {
            "period": {
              "groupSlug": "contentEventSettings",
              "priority": 10,
              "render": true,
              "subName": "period",
              "label": "Period",
              "description": "Select the default time period for events.",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/select",
                "type": "field",
                "props": {
                  "options": {
                    "week":    { "label": "Week" },
                    "month":   { "label": "Month" },
                    "quarter": { "label": "Quarter" },
                    "year":    { "label": "Year" },
                    "all":     { "label": "All" }
                  }
                }
              }
            },
            "periodCount": {
              "groupSlug": "contentEventSettings",
              "priority": 15,
              "render": true,
              "subName": "periodCount",
              "label": "Period Count",
              "description": "Number of periods to display (e.g. 2 = 2 weeks, 2 months, 2 quarters, or 2 years). Default: 1.",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/range",
                "type": "field",
                "props": {
                  "min": 1,
                  "max": 12,
                  "step": 1,
                  "defaultValue": "1",
                  "defaultUnit": "",
                  "allowedUnits": []
                }
              }
            },
            "count": {
              "groupSlug": "contentEventSettings",
              "priority": 20,
              "render": true,
              "subName": "count",
              "label": "Max Events",
              "description": "Maximum number of events to display (0 = all).",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/range",
                "type": "field",
                "props": {
                  "min": 0,
                  "max": 50,
                  "step": 1,
                  "defaultValue": "0",
                  "defaultUnit": "",
                  "allowedUnits": []
                }
              }
            },
            "showPast": {
              "groupSlug": "contentEventSettings",
              "priority": 30,
              "render": true,
              "subName": "showPast",
              "label": "Show Past Events",
              "description": "Show events that have already passed.",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/toggle",
                "type": "field"
              }
            },
            "view": {
              "groupSlug": "contentEventSettings",
              "priority": 40,
              "render": true,
              "subName": "view",
              "label": "View",
              "description": "Choose a default view. Use View Switcher to allow users to change.",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/select",
                "type": "field",
                "props": {
                  "options": {
                    "list":   { "label": "List" },
                    "cards":  { "label": "Cards" },
                    "table":  { "label": "Table" },
                    "slider": { "label": "Slider" }
                  }
                }
              }
            },
            "showFilter": {
              "groupSlug": "contentEventSettings",
              "priority": 50,
              "render": true,
              "subName": "showFilter",
              "label": "Show Period Filter",
              "description": "Display period filter buttons (Week, Month, Quarter, Year, All).",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/toggle",
                "type": "field"
              }
            },
            "showViewSwitcher": {
              "groupSlug": "contentEventSettings",
              "priority": 60,
              "render": true,
              "subName": "showViewSwitcher",
              "label": "Show View Switcher",
              "description": "Display buttons to switch between views.",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/toggle",
                "type": "field"
              }
            },
            "accentColor": {
              "groupSlug": "contentEventSettings",
              "priority": 70,
              "render": true,
              "subName": "accentColor",
              "label": "Accent Color",
              "description": "Color for date badges and active elements.",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/color-picker",
                "type": "field"
              }
            },
            "organizerName": {
              "groupSlug": "contentEventSettings",
              "priority": 80,
              "render": true,
              "subName": "organizerName",
              "label": "Organizer Name",
              "description": "Name of the organization hosting these events (for Schema.org structured data). Leave empty to omit organizer from schema.",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/text",
                "type": "field"
              }
            },
            "organizerUrl": {
              "groupSlug": "contentEventSettings",
              "priority": 85,
              "render": true,
              "subName": "organizerUrl",
              "label": "Organizer URL",
              "description": "Website of the organizer (optional, used in Schema.org output).",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/text",
                "type": "field"
              }
            },
            "schemaEnabled": {
              "groupSlug": "contentEventSettings",
              "priority": 90,
              "render": true,
              "subName": "schemaEnabled",
              "label": "Output Schema.org Data",
              "description": "Embed event data as JSON-LD for search engines and AI. Disable if the page already outputs event schema elsewhere.",
              "features": {
                "sticky": false,
                "responsive": false,
                "hover": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/toggle",
                "type": "field"
              }
            }
          }
        }
      }
    }
  },
  "customCssFields": {
    "heading": {
      "subName": "heading",
      "selectorSuffix": " .dcsve_csv_events__heading"
    },
    "controls": {
      "subName": "controls",
      "selectorSuffix": " .dcsve_csv_events__controls"
    },
    "content": {
      "subName": "content",
      "selectorSuffix": " .dcsve_csv_events__content"
    }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "contentCsvSource": {
        "panel": "content",
        "priority": 5,
        "groupName": "contentCsvSource",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Data"
          }
        }
      },
      "contentEventSettings": {
        "panel": "content",
        "priority": 15,
        "groupName": "contentEventSettings",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Elements"
          }
        }
      }
    }
  }
}
